<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg">

    <!-- ===== Top bar: title + tabs ============================ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="12dp"
        android:paddingTop="14dp"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="PhoneWalker"
            android:textSize="26sp"
            android:textStyle="bold"
            android:letterSpacing="-0.02"
            android:textColor="@color/fg" />

        <TextView
            android:id="@+id/btnTabControl"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:text="Control"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/fg"
            android:background="@drawable/tab_bg_active"
            android:layout_marginEnd="6dp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btnTabDebug"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:text="Debug"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/fg_dim"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- ===== Tab pager (Control | Debug) ============================== -->
    <ViewFlipper
        android:id="@+id/tabFlipper"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:inAnimation="@android:anim/fade_in"
        android:outAnimation="@android:anim/fade_out">

        <!-- ========================= CONTROL TAB ======================= -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="4dp"
                android:paddingBottom="20dp">

                <!-- ========== HERO STATUS CARD ========== -->
                <LinearLayout
                    android:id="@+id/heroCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp"
                    android:background="@drawable/hero_bg_disconnected"
                    android:layout_marginTop="4dp">

                    <!-- Top row: signal + status label + battery gauge -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <dev.robot.companion.ui.SignalBarsView
                            android:id="@+id/signalBars"
                            android:layout_width="28dp"
                            android:layout_height="22dp" />

                        <!-- hidden legacy dot (kept for code compat) -->
                        <View
                            android:id="@+id/bleDot"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:visibility="gone"
                            android:background="@drawable/dot_bad" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/bleStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="disconnected"
                                android:textColor="@color/bad"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.01" />
                            <TextView
                                android:id="@+id/bleMac"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—"
                                android:textColor="@color/fg_mute"
                                android:textSize="10sp"
                                android:fontFamily="monospace" />
                        </LinearLayout>

                        <View
                            android:id="@+id/activityFlash"
                            android:layout_width="24dp"
                            android:layout_height="4dp"
                            android:background="@color/pulse_tx"
                            android:alpha="0" />
                    </LinearLayout>

                    <!-- Hero body: robot face + battery + voltage -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="12dp">

                        <dev.robot.companion.ui.RobotFaceView
                            android:id="@+id/robotFace"
                            android:layout_width="0dp"
                            android:layout_height="128dp"
                            android:layout_weight="1.2" />

                        <FrameLayout
                            android:layout_width="0dp"
                            android:layout_height="128dp"
                            android:layout_weight="1"
                            android:layout_marginStart="4dp">

                            <dev.robot.companion.ui.BatteryRingView
                                android:id="@+id/battRing"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:gravity="center">
                                <TextView
                                    android:id="@+id/battStatus"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="—"
                                    android:textColor="@color/fg"
                                    android:textSize="22sp"
                                    android:textStyle="bold"
                                    android:fontFamily="sans-serif-medium" />
                                <TextView
                                    android:id="@+id/battPct"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text=""
                                    android:textColor="@color/fg_dim"
                                    android:textSize="11sp"
                                    android:letterSpacing="0.1"
                                    android:textAllCaps="true" />
                            </LinearLayout>
                        </FrameLayout>
                    </LinearLayout>

                    <!-- Legacy-compatible battery bar (hidden — kept so old code paths don't NPE) -->
                    <View
                        android:id="@+id/battFill"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:visibility="gone" />

                    <!-- Goal pill -->
                    <LinearLayout
                        android:id="@+id/goalRow"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="7dp"
                        android:paddingBottom="7dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/goal_pill_bg"
                        android:visibility="gone">
                        <TextView
                            android:id="@+id/goalStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🎯 —"
                            android:textColor="@color/ok"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.02" />
                    </LinearLayout>

                    <!-- Speech bubbles -->
                    <LinearLayout
                        android:id="@+id/bubbleYouRow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="start"
                        android:layout_marginTop="8dp"
                        android:visibility="gone">
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="10dp"
                            android:background="@drawable/bubble_bg">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="You"
                                android:textColor="@color/fg_dim"
                                android:textSize="9sp"
                                android:textAllCaps="true"
                                android:letterSpacing="0.18" />
                            <TextView
                                android:id="@+id/bubbleYou"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=""
                                android:textColor="@color/fg"
                                android:textSize="14sp"
                                android:layout_marginTop="1dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/bubbleRobotRow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="end"
                        android:layout_marginTop="4dp"
                        android:visibility="gone">
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="10dp"
                            android:background="@drawable/bubble_robot_bg">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Robot"
                                android:textColor="@color/ok_glow"
                                android:textSize="9sp"
                                android:textAllCaps="true"
                                android:letterSpacing="0.18" />
                            <TextView
                                android:id="@+id/saySnapshot"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=""
                                android:textColor="@color/fg"
                                android:textSize="14sp"
                                android:layout_marginTop="1dp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- legacy ID emptyState kept for compat, now invisible -->
                <LinearLayout
                    android:id="@+id/emptyState"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone" />

                <!-- ========== TALK CARD ========== -->
                <LinearLayout
                    android:id="@+id/talkCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="16dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/card_bg_soft">

                    <FrameLayout
                        android:layout_width="160dp"
                        android:layout_height="160dp">

                        <dev.robot.companion.ui.WaveformRingView
                            android:id="@+id/waveformRing"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent" />

                        <View
                            android:id="@+id/micPulse"
                            android:layout_width="130dp"
                            android:layout_height="130dp"
                            android:layout_gravity="center"
                            android:background="@drawable/talk_button_bg_listening"
                            android:alpha="0" />

                        <TextView
                            android:id="@+id/btnMic"
                            android:layout_width="112dp"
                            android:layout_height="112dp"
                            android:layout_gravity="center"
                            android:gravity="center"
                            android:text="🎤\nTalk"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:letterSpacing="0.02"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="@drawable/talk_button_bg" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/micHint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Tap to talk · “hey robot, walk forward”"
                        android:textColor="@color/fg_dim"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- ========== REMOTE GRID ========== -->
                <LinearLayout
                    android:id="@+id/remoteCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/card_bg_soft">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="POSES"
                        android:textColor="@color/fg_dim"
                        android:textSize="10sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.22" />

                    <!-- 2x2 pose grid -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="10dp">

                        <LinearLayout android:id="@+id/btnPoseNeutral"
                            android:layout_width="0dp" android:layout_height="78dp"
                            android:layout_weight="1" android:orientation="vertical"
                            android:gravity="center"
                            android:clickable="true" android:focusable="true"
                            android:background="@drawable/remote_tile_bg">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🐕"
                                android:textSize="22sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Neutral"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:textColor="@color/fg"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>

                        <LinearLayout android:id="@+id/btnPoseBow"
                            android:layout_width="0dp" android:layout_height="78dp"
                            android:layout_weight="1" android:layout_marginStart="8dp"
                            android:orientation="vertical" android:gravity="center"
                            android:clickable="true" android:focusable="true"
                            android:background="@drawable/remote_tile_bg">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🙇"
                                android:textSize="22sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Bow"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:textColor="@color/fg"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">

                        <LinearLayout android:id="@+id/btnPoseLeanLeft"
                            android:layout_width="0dp" android:layout_height="78dp"
                            android:layout_weight="1" android:orientation="vertical"
                            android:gravity="center"
                            android:clickable="true" android:focusable="true"
                            android:background="@drawable/remote_tile_bg">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="◀"
                                android:textSize="22sp"
                                android:textColor="@color/accent_cyan" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Lean Left"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:textColor="@color/fg"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>

                        <LinearLayout android:id="@+id/btnPoseLeanRight"
                            android:layout_width="0dp" android:layout_height="78dp"
                            android:layout_weight="1" android:layout_marginStart="8dp"
                            android:orientation="vertical" android:gravity="center"
                            android:clickable="true" android:focusable="true"
                            android:background="@drawable/remote_tile_bg">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="▶"
                                android:textSize="22sp"
                                android:textColor="@color/accent_cyan" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Lean Right"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:textColor="@color/fg"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1px"
                        android:layout_marginTop="14dp"
                        android:background="@color/divider" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="DRIVE"
                        android:textColor="@color/fg_dim"
                        android:textSize="10sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.22" />

                    <!-- Walk / Jump / STOP -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="10dp">

                        <LinearLayout android:id="@+id/btnWalk"
                            android:layout_width="0dp" android:layout_height="64dp"
                            android:layout_weight="1" android:orientation="horizontal"
                            android:gravity="center"
                            android:clickable="true" android:focusable="true"
                            android:background="@drawable/walk_button_bg">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🚶"
                                android:textSize="18sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="WALK"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="@color/fg"
                                android:letterSpacing="0.1"
                                android:layout_marginStart="8dp" />
                        </LinearLayout>

                        <LinearLayout android:id="@+id/btnJump"
                            android:layout_width="0dp" android:layout_height="64dp"
                            android:layout_weight="1" android:layout_marginStart="8dp"
                            android:orientation="horizontal" android:gravity="center"
                            android:clickable="true" android:focusable="true"
                            android:background="@drawable/jump_button_bg">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="⬆"
                                android:textSize="18sp"
                                android:textColor="@color/warn" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="JUMP"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="@color/fg"
                                android:letterSpacing="0.1"
                                android:layout_marginStart="8dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView android:id="@+id/btnEmergencyStop"
                        android:layout_width="match_parent"
                        android:layout_height="66dp"
                        android:layout_marginTop="8dp"
                        android:text="■  EMERGENCY STOP"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="#FFFFFF"
                        android:letterSpacing="0.16"
                        android:gravity="center"
                        android:clickable="true" android:focusable="true"
                        android:background="@drawable/stop_button_bg" />
                </LinearLayout>

                <!-- ========== TIMELINE ========== -->
                <LinearLayout
                    android:id="@+id/timelineCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/card_bg_soft">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="ACTIVITY"
                        android:textColor="@color/fg_dim"
                        android:textSize="10sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.22" />

                    <LinearLayout
                        android:id="@+id/timelineList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="4dp" />

                    <TextView
                        android:id="@+id/timelineEmpty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:gravity="center"
                        android:text="Nothing yet. Try saying “hey robot, sit.”"
                        android:textColor="@color/fg_mute"
                        android:textSize="12sp" />
                </LinearLayout>

            </LinearLayout>
        </ScrollView>

        <!-- ========================= DEBUG TAB ========================= -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="4dp"
                android:paddingBottom="20dp">

                <!-- Build header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp"
                    android:background="@drawable/card_bg_soft">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="BUILD"
                        android:textColor="@color/fg_dim"
                        android:textSize="10sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.22" />
                    <TextView
                        android:id="@+id/buildInfo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text=""
                        android:textColor="@color/fg"
                        android:textSize="13sp"
                        android:fontFamily="monospace" />
                </LinearLayout>

                <!-- Connect / disconnect / vision / cancel row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="10dp">
                    <Button
                        android:id="@+id/btnScan"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Connect" />
                    <Button
                        android:id="@+id/btnDisconnect"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:text="Disconnect" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="6dp">
                    <Button
                        android:id="@+id/btnLookFor"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Look for…" />
                    <Button
                        android:id="@+id/btnCancel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:text="Cancel goal" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="LOG"
                    android:textColor="@color/fg_dim"
                    android:textSize="10sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.22" />

                <TextView
                    android:id="@+id/bleLog"
                    android:layout_width="match_parent"
                    android:layout_height="280dp"
                    android:layout_marginTop="4dp"
                    android:padding="10dp"
                    android:background="@drawable/card_bg_soft"
                    android:fontFamily="monospace"
                    android:textSize="11sp"
                    android:textColor="@color/fg"
                    android:scrollbars="vertical" />

                <!-- Settings -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="SETTINGS"
                    android:textColor="@color/fg_dim"
                    android:textSize="10sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.22" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="DeepInfra API key"
                    android:textColor="@color/fg"
                    android:textSize="12sp" />
                <EditText
                    android:id="@+id/editApiKey"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="paste key"
                    android:textColor="@color/fg"
                    android:textColorHint="#777"
                    android:inputType="textNoSuggestions"
                    android:background="@drawable/card_bg_soft"
                    android:padding="10dp"
                    android:textSize="12sp"
                    android:fontFamily="monospace" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Planner model"
                    android:textColor="@color/fg"
                    android:textSize="12sp" />
                <EditText
                    android:id="@+id/editPlannerModel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Qwen/Qwen2.5-72B-Instruct"
