<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#2A1818"
                android:centerColor="#241515"
                android:endColor="#131014" />
            <corners android:radius="20dp" />
            <stroke android:width="1px" android:color="#3A2424" />
        </shape>
    </item>
</layer-list>
