<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#33FFC107">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#2A2414"
                android:endColor="#1E1C13" />
            <corners android:radius="16dp" />
            <stroke android:width="1px" android:color="#4A3E1E" />
        </shape>
    </item>
</ripple>
