<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#17251B"
                android:centerColor="#1C2A22"
                android:endColor="#13171A" />
            <corners android:radius="20dp" />
            <stroke android:width="1px" android:color="#2A3A2E" />
        </shape>
    </item>
</layer-list>
